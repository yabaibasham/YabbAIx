# ════════════════════════════════════════════════════════════════
# YABBAI v5 - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ════════════════════════════════════════════════════════════════

# ── DATABASE ───────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=yabbai_v5

# ── LLM PROVIDERS ──────────────────────────────────────────────────
# Emergent Universal Key (required for Sentinel/Scraper/Janitor)
EMERGENT_LLM_KEY=your_emergent_universal_key

# OpenAI (for GPT-5.2, GPT-4, etc.)
OPENAI_API_KEY=sk-proj-...

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=your_gemini_key

# NVIDIA NIM Models
NEMOTRON_NVIDIA_API_KEY=your_nvidia_key
MISTRAL_NVIDIA_API_KEY=your_nvidia_key
DEEPSEEK_PRO_API_KEY=your_deepseek_key
MOONSHOT_API_KEY=your_moonshot_key
GEMMA_NVIDIA_API_KEY=your_nvidia_key
GLM_NVIDIA_API_KEY=your_nvidia_key

# ── BLOCKCHAIN RPC ─────────────────────────────────────────────────
# Base L2 (Ethereum)
BASE_RPC_URL=https://mainnet.base.org

# Sui Network
SUI_RPC_URL=https://fullnode.mainnet.sui.io

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── PAYMENT PROCESSING ─────────────────────────────────────────────
# Stripe (for audit & retainer payments)
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── NOTIFICATIONS ─────────────────────────────────────────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── WITHDRAWAL / TREASURY ──────────────────────────────────────────
# Coinspot Base L2 (ERC-20) deposit address for cashout
WITHDRAWAL_DESTINATION=0x...

# Network for withdrawals (base, sui, solana)
WITHDRAWAL_NETWORK=base

# Gas Reserve and Hard Floor (in ETH)
GAS_RESERVE_ETH=0.01
GAS_HARD_FLOOR_ETH=0.005

# Sui Gas Reserve (in SUI)
GAS_RESERVE_SUI=5.0

# ── TREASURY WALLETS ───────────────────────────────────────────────
# Secure holding wallet (cold storage)
TREASURY_HOLDING_WALLET=0x...

# Transacting wallet (hot wallet for operations)
TREASURY_TRANSACTING_WALLET=0x...

# ── SOLANA WALLET KEYPAIR ──────────────────────────────────────────
# Path to Solana keypair JSON file (not required for read-only)
# WALLET_KEYPAIR_PATH=/path/to/keypair.json

# ── API CONFIGURATION ──────────────────────────────────────────────
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yabbai.example.com

# Gold-Hunter worker cycle interval (seconds)
GOLD_HUNTER_INTERVAL=300

# ── FRONTEND CONFIGURATION ─────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_ENVIRONMENT=development

# ── DEVELOPMENT / PRODUCTION ──────────────────────────────────────
NODE_ENV=development
PYTHON_ENV=development
